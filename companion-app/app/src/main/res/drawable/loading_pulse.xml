<?xml version="1.0" encoding="utf-8"?>
<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">

    <aapt:attr name="android:drawable">
        <vector
            android:width="48dp"
            android:height="48dp"
            android:viewportWidth="48"
            android:viewportHeight="48">

            <!-- Outer pulsing wave -->
            <group android:name="outer_wave">
                <path
                    android:name="outer_path"
                    android:pathData="M24,12 Q30,18 24,24 Q18,30 24,36"
                    android:strokeAlpha="0.6"
                    android:strokeColor="@color/primary"
                    android:strokeLineCap="round"
                    android:strokeWidth="3" />
            </group>

            <!-- Middle wave -->
            <group android:name="middle_wave">
                <path
                    android:name="middle_path"
                    android:pathData="M24,16 Q28,20 24,24 Q20,28 24,32"
                    android:strokeAlpha="0.8"
                    android:strokeColor="@color/primary"
                    android:strokeLineCap="round"
                    android:strokeWidth="2.5" />
            </group>

            <!-- Inner core -->
            <group android:name="inner_core">
                <path
                    android:name="core_path"
                    android:fillColor="@color/accent"
                    android:pathData="M24,20 Q26,22 24,24 Q22,26 24,28 Q26,30 24,32 L24,20 Z" />
            </group>
        </vector>
    </aapt:attr>

    <!-- Outer wave pulse animation -->
    <target android:name="outer_wave">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:duration="1500"
                    android:propertyName="scaleX"
                    android:repeatCount="infinite"
                    android:repeatMode="restart"
                    android:valueFrom="1.0"
                    android:valueTo="1.3"
                    android:valueType="floatType" />
                <objectAnimator
                    android:duration="1500"
                    android:propertyName="scaleY"
                    android:repeatCount="infinite"
                    android:repeatMode="restart"
                    android:valueFrom="1.0"
                    android:valueTo="1.3"
                    android:valueType="floatType" />
            </set>
        </aapt:attr>
    </target>

    <!-- Middle wave pulse animation -->
    <target android:name="middle_wave">
        <aapt:attr name="android:animation">
            <set android:startOffset="200">
                <objectAnimator
                    android:duration="1500"
                    android:propertyName="scaleX"
                    android:repeatCount="infinite"
                    android:repeatMode="restart"
                    android:valueFrom="1.0"
                    android:valueTo="1.2"
                    android:valueType="floatType" />
                <objectAnimator
                    android:duration="1500"
                    android:propertyName="scaleY"
                    android:repeatCount="infinite"
                    android:repeatMode="restart"
                    android:valueFrom="1.0"
                    android:valueTo="1.2"
                    android:valueType="floatType" />
            </set>
        </aapt:attr>
    </target>

    <!-- Core pulse animation -->
    <target android:name="inner_core">
        <aapt:attr name="android:animation">
            <set android:startOffset="400">
                <objectAnimator
                    android:duration="1500"
                    android:propertyName="alpha"
                    android:repeatCount="infinite"
                    android:repeatMode="reverse"
                    android:valueFrom="1.0"
                    android:valueTo="0.4"
                    android:valueType="floatType" />
            </set>
        </aapt:attr>
    </target>
</animated-vector>
