<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface" />
        </shape>
    </item>

    <!-- Wave pattern overlay -->
    <item>
        <vector
            android:width="360dp"
            android:height="360dp"
            android:viewportWidth="360"
            android:viewportHeight="360">
            <path
                android:fillAlpha="0.05"
                android:fillColor="@color/primary"
                android:pathData="M0,120 Q90,80 180,120 T360,120 L360,180 Q270,220 180,180 T0,180 Z" />
            <path
                android:fillAlpha="0.03"
                android:fillColor="@color/primary"
                android:pathData="M0,200 Q90,160 180,200 T360,200 L360,260 Q270,300 180,260 T0,260 Z" />
            <path
                android:fillAlpha="0.02"
                android:fillColor="@color/accent"
                android:pathData="M0,40 Q90,0 180,40 T360,40 L360,100 Q270,140 180,100 T0,100 Z" />
        </vector>
    </item>
</layer-list>
