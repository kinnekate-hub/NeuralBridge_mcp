<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_medium">

    <!-- Filter Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Spinner
            android:id="@+id/logFilterSpinner"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card_wave"
            android:paddingStart="@dimen/spacing_small"
            android:paddingEnd="@dimen/spacing_small" />

        <Button
            android:id="@+id/btnClearLogs"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/spacing_small"
            android:backgroundTint="@color/status_error"
            android:text="CLEAR"
            android:textAppearance="@style/TextAppearance.NeuralBridge.LabelMedium"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btnPauseLogs"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="@dimen/spacing_small"
            android:backgroundTint="@color/wave_blue"
            android:text="PAUSE"
            android:textAppearance="@style/TextAppearance.NeuralBridge.LabelMedium"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- Log RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/logRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_small"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_medium" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/logEmptyText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No commands logged yet.\nExecute MCP commands to see activity here."
        android:textAppearance="@style/TextAppearance.NeuralBridge.BodyMedium"
        android:textColor="@color/text_medium_emphasis"
        android:visibility="visible" />

</LinearLayout>
