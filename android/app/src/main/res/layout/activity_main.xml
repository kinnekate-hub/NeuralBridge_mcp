<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_wave_pattern"
    android:orientation="vertical">

    <!-- Persistent Gradient Header -->
    <include layout="@layout/header_gradient" />

    <!-- Tab Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="?attr/colorSurface"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tabStatus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Status"
            android:textAppearance="@style/TextAppearance.NeuralBridge.LabelLarge"
            android:textColor="@color/wave_blue"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabSetup"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Setup"
            android:textAppearance="@style/TextAppearance.NeuralBridge.LabelLarge"
            android:textColor="@color/text_medium_emphasis" />

        <TextView
            android:id="@+id/tabLogs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Logs"
            android:textAppearance="@style/TextAppearance.NeuralBridge.LabelLarge"
            android:textColor="@color/text_medium_emphasis" />

    </LinearLayout>

    <!-- Tab Indicator -->
    <View
        android:id="@+id/tabIndicator"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@drawable/bg_tab_indicator" />

    <!-- Tab Content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include
            android:id="@+id/tabStatusContent"
            layout="@layout/tab_status"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <include
            android:id="@+id/tabSetupContent"
            layout="@layout/tab_setup"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <include
            android:id="@+id/tabLogsContent"
            layout="@layout/tab_logs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
