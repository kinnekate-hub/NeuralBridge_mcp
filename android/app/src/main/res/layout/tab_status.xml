<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_medium">

        <!-- Connection Hero Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_wave"
            android:elevation="@dimen/elevation_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/spacing_large">

            <TextView
                android:id="@+id/connectionStatusIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡"
                android:textSize="32sp" />

            <TextView
                android:id="@+id/connectionStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:text="WAITING FOR CONNECTION"
                android:textAppearance="@style/TextAppearance.NeuralBridge.TitleMedium"
                android:textColor="@color/text_medium_emphasis"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/connectionDetailText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_tiny"
                android:text="Waiting for connection"
                android:textAppearance="@style/TextAppearance.NeuralBridge.BodySmall"
                android:textColor="@color/text_medium_emphasis" />

            <Switch
                android:id="@+id/masterToggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_medium"
                android:checked="false"
                android:text="ENABLE"
                android:textAppearance="@style/TextAppearance.NeuralBridge.LabelMedium"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 3-Up Status Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Accessibility Status -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/spacing_tiny"
                android:layout_weight="1"
                android:background="@drawable/bg_card_wave"
                android:elevation="@dimen/elevation_card"
                android:orientation="vertical"
                android:padding="@dimen/spacing_small">

                <View
                    android:id="@+id/accessibilityStatusBar"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@color/status_inactive" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="Accessibility"
                    android:textAppearance="@style/TextAppearance.NeuralBridge.LabelSmall"
                    android:textColor="@color/text_medium_emphasis" />

                <TextView
                    android:id="@+id/accessibilityStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFF"
                    android:textAppearance="@style/TextAppearance.NeuralBridge.LabelMedium"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- TCP Server Status -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_tiny"
                android:layout_marginEnd="@dimen/spacing_tiny"
                android:layout_weight="1"
                android:background="@drawable/bg_card_wave"
                android:elevation="@dimen/elevation_card"
                android:orientation="vertical"
                android:padding="@dimen/spacing_small">

                <View
                    android:id="@+id/mcpStatusBar"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@color/status_inactive" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="MCP Server"
                    android:textAppearance="@style/TextAppearance.NeuralBridge.LabelSmall"
                    android:textColor="@color/text_medium_emphasis" />

                <TextView
                    android:id="@+id/mcpStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFF"
                    android:textAppearance="@style/TextAppearance.NeuralBridge.LabelMedium"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- MediaProjection Status -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_tiny"
                android:layout_weight="1"
                android:background="@drawable/bg_card_wave"
                android:elevation="@dimen/elevation_card"
                android:orientation="vertical"
                android:padding="@dimen/spacing_small">

                <View
                    android:id="@+id/screenshotStatusBar"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:background="@color/status_inactive" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_small"
                    android:text="Screenshots"
                    android:textAppearance="@style/TextAppearance.NeuralBridge.LabelSmall"
                    android:textColor="@color/text_medium_emphasis" />

                <TextView
                    android:id="@+id/screenshotStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="OFF"
                    android:textAppearance="@style/TextAppearance.NeuralBridge.LabelMedium"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Device Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:background="@drawable/bg_card_wave"
            android:elevation="@dimen/elevation_card"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEVICE INFO"
                android:textAppearance="@style/TextAppearance.NeuralBridge.LabelMedium"
                android:textColor="@color/wave_purple"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/deviceInfoText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:fontFamily="monospace"
                android:text="Loading..."
                android:textAppearance="@style/TextAppearance.NeuralBridge.BodySmall"
                android:textColor="@color/text_medium_emphasis" />

        </LinearLayout>

        <!-- Performance Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_medium"
            android:background="@drawable/bg_card_wave"
            android:elevation="@dimen/elevation_card"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERFORMANCE"
                android:textAppearance="@style/TextAppearance.NeuralBridge.LabelMedium"
                android:textColor="@color/wave_purple"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_small"
                android:orientation="horizontal"
                android:weightSum="4">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/perfP50"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.NeuralBridge.TitleMedium"
                        android:textColor="@color/wave_blue"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="P50"
                        android:textAppearance="@style/TextAppearance.NeuralBridge.LabelSmall"
                        android:textColor="@color/text_medium_emphasis" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/perfP95"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.NeuralBridge.TitleMedium"
                        android:textColor="@color/warning"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="P95"
                        android:textAppearance="@style/TextAppearance.NeuralBridge.LabelSmall"
                        android:textColor="@color/text_medium_emphasis" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/perfP99"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textAppearance="@style/TextAppearance.NeuralBridge.TitleMedium"
                        android:textColor="@color/status_error"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="P99"
                        android:textAppearance="@style/TextAppearance.NeuralBridge.LabelSmall"
                        android:textColor="@color/text_medium_emphasis" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/perfCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textAppearance="@style/TextAppearance.NeuralBridge.TitleMedium"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total"
                        android:textAppearance="@style/TextAppearance.NeuralBridge.LabelSmall"
                        android:textColor="@color/text_medium_emphasis" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
