<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================ -->
    <!-- Text Appearances (Material Design 3 Type Scale) -->
    <!-- ============================================ -->

    <!-- Display Styles (Large, Prominent Headlines) -->
    <style name="TextAppearance.NeuralBridge.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textSize">57sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:lineHeight">64sp</item>
        <item name="android:letterSpacing">-0.0025</item>
    </style>

    <style name="TextAppearance.NeuralBridge.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:textSize">45sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineHeight">52sp</item>
    </style>

    <!-- Headline Styles -->
    <style name="TextAppearance.NeuralBridge.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineHeight">40sp</item>
    </style>

    <style name="TextAppearance.NeuralBridge.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineHeight">36sp</item>
    </style>

    <style name="TextAppearance.NeuralBridge.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineHeight">32sp</item>
    </style>

    <!-- Title Styles -->
    <style name="TextAppearance.NeuralBridge.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:lineHeight">28sp</item>
    </style>

    <style name="TextAppearance.NeuralBridge.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:letterSpacing">0.0015</item>
    </style>

    <style name="TextAppearance.NeuralBridge.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:letterSpacing">0.001</item>
    </style>

    <!-- Body Styles -->
    <style name="TextAppearance.NeuralBridge.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:letterSpacing">0.005</item>
    </style>

    <style name="TextAppearance.NeuralBridge.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:letterSpacing">0.0025</item>
    </style>

    <style name="TextAppearance.NeuralBridge.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineHeight">16sp</item>
        <item name="android:letterSpacing">0.004</item>
    </style>

    <!-- Label Styles -->
    <style name="TextAppearance.NeuralBridge.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:lineHeight">20sp</item>
        <item name="android:letterSpacing">0.001</item>
    </style>

    <style name="TextAppearance.NeuralBridge.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:lineHeight">16sp</item>
        <item name="android:letterSpacing">0.005</item>
    </style>

    <style name="TextAppearance.NeuralBridge.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:lineHeight">16sp</item>
        <item name="android:letterSpacing">0.005</item>
    </style>

    <!-- ============================================ -->
    <!-- Button Styles (Wave-inspired) -->
    <!-- ============================================ -->

    <!-- Filled Button (Primary Action) -->
    <style name="Widget.NeuralBridge.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">@dimen/corner_radius_button</item>
        <item name="android:minHeight">@dimen/button_height_default</item>
        <item name="android:paddingStart">@dimen/spacing_large</item>
        <item name="android:paddingEnd">@dimen/spacing_large</item>
        <item name="android:textAppearance">@style/TextAppearance.NeuralBridge.LabelLarge</item>
        <item name="elevation">@dimen/elevation_button</item>
    </style>

    <!-- Filled Tonal Button (Secondary Action) -->
    <style name="Widget.NeuralBridge.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">@dimen/corner_radius_button</item>
        <item name="android:minHeight">@dimen/button_height_default</item>
        <item name="android:paddingStart">@dimen/spacing_large</item>
        <item name="android:paddingEnd">@dimen/spacing_large</item>
        <item name="android:textAppearance">@style/TextAppearance.NeuralBridge.LabelLarge</item>
    </style>

    <!-- Outlined Button (Tertiary Action) -->
    <style name="Widget.NeuralBridge.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/corner_radius_button</item>
        <item name="android:minHeight">@dimen/button_height_default</item>
        <item name="android:paddingStart">@dimen/spacing_large</item>
        <item name="android:paddingEnd">@dimen/spacing_large</item>
        <item name="android:textAppearance">@style/TextAppearance.NeuralBridge.LabelLarge</item>
        <item name="strokeWidth">@dimen/stroke_width_default</item>
    </style>

    <!-- Text Button (Low Priority Action) -->
    <style name="Widget.NeuralBridge.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">@dimen/corner_radius_button</item>
        <item name="android:minHeight">@dimen/button_height_default</item>
        <item name="android:paddingStart">@dimen/spacing_medium</item>
        <item name="android:paddingEnd">@dimen/spacing_medium</item>
        <item name="android:textAppearance">@style/TextAppearance.NeuralBridge.LabelLarge</item>
    </style>

    <!-- Icon Button -->
    <style name="Widget.NeuralBridge.Button.Icon" parent="Widget.Material3.Button.IconButton">
        <item name="cornerRadius">@dimen/corner_radius_small</item>
    </style>

    <!-- FAB (Floating Action Button) -->
    <style name="Widget.NeuralBridge.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="shapeAppearance">@style/ShapeAppearance.NeuralBridge.FloatingActionButton</item>
        <item name="elevation">@dimen/elevation_fab</item>
    </style>

    <style name="ShapeAppearance.NeuralBridge.FloatingActionButton" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_radius_fab</item>
    </style>

    <!-- ============================================ -->
    <!-- Card Styles (Wave-inspired elevation) -->
    <!-- ============================================ -->

    <!-- Elevated Card (Default) -->
    <style name="Widget.NeuralBridge.Card.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="shapeAppearance">@style/ShapeAppearance.NeuralBridge.Card</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="contentPadding">@dimen/spacing_medium</item>
    </style>

    <!-- Filled Card -->
    <style name="Widget.NeuralBridge.Card.Filled" parent="Widget.Material3.CardView.Filled">
        <item name="shapeAppearance">@style/ShapeAppearance.NeuralBridge.Card</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
        <item name="contentPadding">@dimen/spacing_medium</item>
    </style>

    <!-- Outlined Card -->
    <style name="Widget.NeuralBridge.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="shapeAppearance">@style/ShapeAppearance.NeuralBridge.Card</item>
        <item name="strokeWidth">@dimen/stroke_width_default</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="contentPadding">@dimen/spacing_medium</item>
    </style>

    <style name="ShapeAppearance.NeuralBridge.Card" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_radius_card</item>
    </style>

    <!-- ============================================ -->
    <!-- Input Field Styles -->
    <!-- ============================================ -->

    <!-- Filled Text Field (Default) -->
    <style name="Widget.NeuralBridge.TextField" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_radius_input</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_radius_input</item>
        <item name="boxCornerRadiusBottomStart">0dp</item>
        <item name="boxCornerRadiusBottomEnd">0dp</item>
        <item name="boxStrokeWidth">@dimen/stroke_width_input</item>
        <item name="boxStrokeWidthFocused">@dimen/stroke_width_input_focused</item>
        <item name="android:textAppearance">@style/TextAppearance.NeuralBridge.BodyLarge</item>
        <item name="hintTextAppearance">@style/TextAppearance.NeuralBridge.BodySmall</item>
    </style>

    <!-- Outlined Text Field -->
    <style name="Widget.NeuralBridge.TextField.Outlined" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_radius_input</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_radius_input</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_radius_input</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_radius_input</item>
        <item name="boxStrokeWidth">@dimen/stroke_width_input</item>
        <item name="boxStrokeWidthFocused">@dimen/stroke_width_input_focused</item>
        <item name="android:textAppearance">@style/TextAppearance.NeuralBridge.BodyLarge</item>
        <item name="hintTextAppearance">@style/TextAppearance.NeuralBridge.BodySmall</item>
    </style>

    <!-- ============================================ -->
    <!-- Chip Styles -->
    <!-- ============================================ -->

    <style name="Widget.NeuralBridge.Chip.Assist" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">@dimen/corner_radius_chip</item>
        <item name="android:textAppearance">@style/TextAppearance.NeuralBridge.LabelLarge</item>
    </style>

    <style name="Widget.NeuralBridge.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">@dimen/corner_radius_chip</item>
        <item name="android:textAppearance">@style/TextAppearance.NeuralBridge.LabelLarge</item>
    </style>

    <style name="Widget.NeuralBridge.Chip.Input" parent="Widget.Material3.Chip.Input">
        <item name="chipCornerRadius">@dimen/corner_radius_chip</item>
        <item name="android:textAppearance">@style/TextAppearance.NeuralBridge.LabelLarge</item>
    </style>

    <!-- ============================================ -->
    <!-- Switch & Checkbox Styles -->
    <!-- ============================================ -->

    <style name="Widget.NeuralBridge.Switch" parent="Widget.Material3.CompoundButton.Switch">
        <item name="trackCornerRadius">@dimen/corner_radius_switch_track</item>
        <item name="thumbRadius">@dimen/corner_radius_switch_thumb</item>
    </style>

    <!-- ============================================ -->
    <!-- Toolbar & AppBar Styles -->
    <!-- ============================================ -->

    <style name="Widget.NeuralBridge.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/TextAppearance.NeuralBridge.TitleLarge</item>
        <item name="subtitleTextAppearance">@style/TextAppearance.NeuralBridge.BodyMedium</item>
        <item name="android:elevation">@dimen/elevation_appbar</item>
    </style>

    <style name="Widget.NeuralBridge.TopAppBar" parent="Widget.Material3.AppBarLayout">
        <item name="android:elevation">@dimen/elevation_appbar</item>
    </style>

    <!-- ============================================ -->
    <!-- Bottom Navigation & Navigation Rail -->
    <!-- ============================================ -->

    <style name="Widget.NeuralBridge.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemTextAppearanceActive">@style/TextAppearance.NeuralBridge.LabelMedium</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.NeuralBridge.LabelMedium</item>
        <item name="elevation">@dimen/elevation_bottom_nav</item>
    </style>

    <!-- ============================================ -->
    <!-- Dialog & Bottom Sheet Styles -->
    <!-- ============================================ -->

    <style name="Widget.NeuralBridge.Dialog" parent="@android:style/Theme.Material.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>

    <!-- ============================================ -->
    <!-- Progress Indicators -->
    <!-- ============================================ -->

    <style name="Widget.NeuralBridge.CircularProgressIndicator" parent="Widget.Material3.CircularProgressIndicator">
        <item name="trackThickness">@dimen/progress_indicator_track_thickness</item>
        <item name="indicatorSize">@dimen/progress_indicator_size</item>
    </style>

    <style name="Widget.NeuralBridge.LinearProgressIndicator" parent="Widget.Material3.LinearProgressIndicator">
        <item name="trackThickness">@dimen/progress_indicator_track_thickness</item>
        <item name="trackCornerRadius">@dimen/corner_radius_small</item>
    </style>

    <!-- ============================================ -->
    <!-- Divider Styles -->
    <!-- ============================================ -->

    <style name="Widget.NeuralBridge.Divider" parent="Widget.Material3.MaterialDivider">
        <item name="android:background">?attr/colorOutlineVariant</item>
        <item name="dividerInsetStart">@dimen/spacing_medium</item>
        <item name="dividerInsetEnd">@dimen/spacing_medium</item>
    </style>
</resources>
